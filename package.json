{
  "name": "vonge-jekyll-template",
  "private": true,
  "description": "Vonge template for CloudCannon",
  "scripts": {
    "jekyll:install": "bundle config set --local path 'vendor/bundle' && BUNDLE_GEMFILE=site/Gemfile bundle install",
    "jekyll": "BUNDLE_GEMFILE=site/Gemfile bundle exec jekyll serve --source site --port 6060 --trace --unpublished",
    "start": "npm run jekyll"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudCannon/vonge-jekyll-template.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CloudCannon/vonge-jekyll-template/issues"
  },
  "homepage": "https://github.com/CloudCannon/vonge-jekyll-template#readme",
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {}
}